# 12-Factor App Configuration for RunLayer
# Copy this file to .env and customize for your environment

# III. Config - Store config in environment variables
ENVIRONMENT=development

# JWT Configuration (REQUIRED in production)
JWT_SECRET_KEY=your-super-secure-jwt-secret-key-at-least-32-characters-long

# CORS Configuration (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,https://runlayer.com

# Backing Services - Database
DATABASE_URL=postgresql+asyncpg://username:password@localhost:5432/runlayer

# Backing Services - Redis
REDIS_URL=redis://localhost:6379/0

# Database Pool Configuration (12-Factor: explicit resource limits)
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# Rate Limiting Configuration
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW=3600

# Logging Configuration
LOG_LEVEL=INFO

# Production Example:
# ENVIRONMENT=production
# JWT_SECRET_KEY=prod-super-secure-jwt-secret-key-from-secrets-manager
# DATABASE_URL=postgresql+asyncpg://user:pass@prod-db.amazonaws.com:5432/runlayer
# REDIS_URL=redis://prod-redis.amazonaws.com:6379/0
# CORS_ORIGINS=https://app.runlayer.com,https://api.runlayer.com
# DB_POOL_SIZE=50
# DB_MAX_OVERFLOW=100
# LOG_LEVEL=WARNING
